# Authentication - required untuk akses API (kecuali /health)
PROXY_API_KEY=

# Model name yang di-expose ke client (HARUS exact match saat request)
MODEL_NAME=WAW-SUPER

# Timeout & Retry Settings
REQUEST_TIMEOUT=30
MAX_RETRIES=1

# Model Priority: Konektika (1) -> DataByte (2) -> GLM (3)
# Priority 1: Konektika
KONEKTIKA_API_KEY=
KONEKTIKA_BASE_URL=https://konektika.web.id/v1
KONEKTIKA_MODEL=kimi-pro
KONEKTIKA_ENABLED=true

# Priority 2: DataByte
DATABYTE_API_KEY=
DATABYTE_BASE_URL=https://ai.databyte.co.id/anthropic/v1
DATABYTE_MODEL=databyte-m1
DATABYTE_ENABLED=true

# Priority 3: GLM (last resort)
GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/anthropic
GLM_MODEL=GLM-4.7
GLM_ENABLED=true